# Set one TMDb auth option:
TMDB_BEARER_TOKEN=
TMDB_API_KEY=

TMDB_LANGUAGE=en-US
TMDB_MIN_SCORE=7
TMDB_MIN_VOTE_COUNT=300
TMDB_RELEASE_WINDOW_DAYS=30
TMDB_PRIMARY_RELEASE_DATE_GTE=2000-01-01

RADARR_URL=http://radarr:7878
RADARR_API_KEY=
RADARR_ROOT_FOLDER_PATH=/data/media/movies

# Set one quality profile option:
RADARR_QUALITY_PROFILE_ID=
RADARR_QUALITY_PROFILE_NAME=HD-1080p

RADARR_SEARCH_ON_ADD=true
RADARR_MONITORED=true
RADARR_MINIMUM_AVAILABILITY=released
DRY_RUN=false
